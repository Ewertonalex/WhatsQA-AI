# Identidade do bot
BOT_NAME=WhatsQA AI

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
MAX_TOKENS=2048
TEMPERATURE=0.3

# Banco de dados (SQLite agora; PostgreSQL no futuro)
DATABASE_URL="file:./dev.db"

# Sessão WhatsApp (LocalAuth) — independente do número do chip
SESSION_NAME=whatsqa-ai

# Administrador (formato internacional, sem +). Ex: 5511999999999
ADMIN_NUMBER=5511999999999

# Logging
LOG_LEVEL=info

# Servidor HTTP (Dashboard)
PORT=3000
NODE_ENV=development
